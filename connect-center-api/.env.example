# App
APP_NAME=connect-center-services
SQL_ECHO=false
DB_AUTO_CREATE=false

# DB vendor selection: mariadb
DB_VENDOR=mariadb

# MariaDB (asyncmy)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Server bind addresses
HOST=127.0.0.1
PORT=5555
DOCS_HOST=127.0.0.1
DOCS_PORT=3001

# Docs / API public URLs
# Local docs:
# PUBLIC_DOCS_BASE_URL=http://127.0.0.1:3001
# PUBLIC_API_BASE_URL=http://127.0.0.1:5555
PUBLIC_DOCS_BASE_URL=
PUBLIC_API_BASE_URL=

# OAuth2 / OIDC (Bearer token auth)
# These are used for OIDC discovery and bearer-token validation.
# The backend verifies the token against:
#   OAUTH2_AUDIENCE if set
#   otherwise OAUTH2_CLIENT_ID
# It then maps the verified token `sub` to a connectCenter user via:
#   oauth2_app (by provider_name, issuer_uri + client_id, or issuer_uri) -> oauth2_app_id
#   app_oauth2_user (by oauth2_app_id + sub) -> app_user
#
OAUTH2_PROVIDER_NAME=
OAUTH2_ISSUER_URI=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_CONFIGURATION_URL=
OAUTH2_AUDIENCE=

# MCP bearer JWT verification for trusted external issuers.
# These must match the token issuer, its JWKS endpoint, and the audience
# expected by connectCenter MCP.
MCP_JWT_ISSUER_URI=
MCP_JWT_JWKS_URI=
MCP_JWT_AUDIENCE=
MCP_JWT_ALGORITHM=
MCP_JWT_LOGIN_ID_CLAIM=login_id
