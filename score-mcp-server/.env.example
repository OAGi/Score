# =============================================================================
# Database Configuration
# =============================================================================

# Option 1: Full connection string (recommended)
# Format: mariadb+mariadbconnector://user:password@host:port/database
# If this is set, individual DATABASE_* variables below are ignored
DATABASE_URL=mariadb+mariadbconnector://user:password@host:port/database

# Option 2: Individual database components (used if DATABASE_URL is not set)
# Database connector/driver (default: mariadb+mariadbconnector)
DATABASE_CONNECTOR=mariadb+mariadbconnector
# Database host address
DATABASE_HOSTNAME=localhost
# Database port number (default: 3306 for MariaDB/MySQL)
DATABASE_PORT=3306
# Database username
DATABASE_USERNAME=score_user
# Database password
DATABASE_PASSWORD=your_password
# Database name
DATABASE_NAME=score_db

# =============================================================================
# Authentication Configuration
# =============================================================================

# Authentication provider class path (e.g., fastmcp.server.auth.oidc_proxy.OIDCProxy)
# If not set, authentication is disabled
AUTH_PROVIDER=fastmcp.server.auth.oidc_proxy.OIDCProxy

# OIDC/OAuth2 Provider Parameters (used with AUTH_PROVIDER_PARAMS_ prefix)
# OIDC configuration discovery URL (e.g., .well-known/openid-configuration endpoint)
AUTH_PROVIDER_PARAMS_CONFIG_URL=https://your-auth-provider/.well-known/openid-configuration
# OAuth2 client ID from your authentication provider
AUTH_PROVIDER_PARAMS_CLIENT_ID=your_client_id
# OAuth2 client secret from your authentication provider
AUTH_PROVIDER_PARAMS_CLIENT_SECRET=your_client_secret
# OAuth2 audience/API identifier
AUTH_PROVIDER_PARAMS_AUDIENCE=your_audience
# Base URL of this application (used for redirects and callbacks)
AUTH_PROVIDER_PARAMS_BASE_URL=http://localhost:8000

# =============================================================================
# Server Configuration
# =============================================================================

# Host address to bind the server to (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0
# Port number to listen on
PORT=8000
# Number of uvicorn worker processes (for production, typically 2-4x CPU cores)
# Note: Only used in Docker/startup scripts, not in main.py
WORKERS=4
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable stateless HTTP mode (required for Docker/containerized deployments)
# If CORS is enabled, this is automatically set to True
STATELESS_HTTP=true

# =============================================================================
# CORS Configuration (optional)
# =============================================================================

# Enable CORS (Cross-Origin Resource Sharing) middleware
CORS_ENABLED=false
# Allowed origins (comma-separated list or '*' for all origins)
CORS_ALLOW_ORIGINS=*
# Allowed HTTP methods (comma-separated list or '*' for all methods)
CORS_ALLOW_METHODS=*
# Allowed HTTP headers (comma-separated list or '*' for all headers)
CORS_ALLOW_HEADERS=*
# Exposed HTTP headers (comma-separated list or '*' for all headers)
CORS_EXPOSE_HEADERS=*
# Allow credentials (cookies, authorization headers) in CORS requests
CORS_ALLOW_CREDENTIALS=false
# Maximum age (in seconds) for preflight OPTIONS request caching
CORS_MAX_AGE=600

# =============================================================================
# Cache Configuration
# =============================================================================

# Cache type: 'memory' (or 'inmemory') for in-memory cache, 'redis' for Redis cache
# In-memory cache is faster but limited to a single process/container
# Redis cache allows sharing cache across multiple processes/containers
CACHE_TYPE=memory

# Cache settings for InMemoryCache (only used when CACHE_TYPE=memory)
# Maximum number of cache entries before LRU (Least Recently Used) eviction
# When limit is reached, oldest entries are removed to make room for new ones
CACHE_MAX_SIZE=1000

# Default TTL (Time To Live) in seconds for cache entries
# After this time, cached entries expire and are removed
# If not set, defaults to 60 seconds (1 minute)
# Individual cache decorators can override this with their own TTL
CACHE_DEFAULT_TTL=60

# Redis Configuration (only used when CACHE_TYPE=redis)
# Redis Cache connection URL (for RedisCache)
# Supported URL schemes:
#   - Single instance: redis://[password@]host:port[/database_number]
#   - Sentinel: redis+sentinel://[password@]host:port[/database_number]?master=master_name
#   - Cluster: redis-cluster://[password@]host:port
# Database number (0-15) is optional, defaults to 0 if not specified
# Example: redis://localhost:6379/0 or redis://:password@redis.example.com:6379/1
REDIS_CACHE_URL=redis://localhost:6379/0

# Redis deployment type: 'single', 'sentinel', or 'cluster'
# If not set, will be auto-detected from REDIS_CACHE_URL scheme:
#   - redis:// or rediss:// -> single instance
#   - redis+sentinel:// or rediss+sentinel:// -> Sentinel
#   - redis-cluster:// or rediss-cluster:// -> Cluster
#REDIS_CACHE_TYPE=single

# Redis Sentinel Configuration (only used when CACHE_TYPE=redis and REDIS_CACHE_TYPE=sentinel)
# Master name for Sentinel mode (default: 'mymaster')
#REDIS_CACHE_SENTINEL_MASTER=mymaster

# Comma-separated list of Sentinel node addresses (format: host1:port1,host2:port2,host3:port3)
# If not set, will try to parse from REDIS_CACHE_URL if it uses redis+sentinel:// scheme
# Example: sentinel1.example.com:26379,sentinel2.example.com:26379,sentinel3.example.com:26379
#REDIS_CACHE_SENTINEL_NODES=sentinel1.example.com:26379,sentinel2.example.com:26379,sentinel3.example.com:26379

# Redis Cluster Configuration (only used when CACHE_TYPE=redis and REDIS_CACHE_TYPE=cluster)
# Comma-separated list of Cluster node addresses (format: host1:port1,host2:port2,host3:port3)
# At least one node is required for cluster discovery. The client will discover other nodes automatically.
# If not set, will try to parse from REDIS_CACHE_URL if it uses redis-cluster:// scheme
# Example: cluster1.example.com:6379,cluster2.example.com:6379,cluster3.example.com:6379
#REDIS_CACHE_CLUSTER_NODES=cluster1.example.com:6379,cluster2.example.com:6379,cluster3.example.com:6379
